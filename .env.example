# Copie pra .env.local (gitignorado) e preencha com os valores reais do seu projeto
# Supabase (Project Settings → API). VITE_SUPABASE_URL/ANON_KEY são públicas por design
# (embutidas no bundle do cliente, protegidas por RLS) — mesmo assim não versionamos
# arquivo de env, só por higiene (ver .gitignore).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
